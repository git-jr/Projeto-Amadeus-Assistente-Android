<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:context=".activity.SplashScreenActivity">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/surface_panel"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/outline_subtle"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="32dp">

            <ImageView
                android:id="@+id/logoAmadeusImageView"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:contentDescription="@string/logo_amadeus"
                android:src="@drawable/ic_logo_white"
                android:tint="@color/colorPrimary" />

            <RelativeLayout
                android:id="@+id/progressoLayout"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ProgressBar
                    android:id="@+id/barraProgresso"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:max="100"
                    android:progressDrawable="@drawable/barra_progresso_cirulo_roxo" />

                <TextView
                    android:id="@+id/progressoTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/colorPrimary" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tituloTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/projeto_amadeus"
                android:textAlignment="center"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/subTituloTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/update_pretty"
                android:textAlignment="center"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
