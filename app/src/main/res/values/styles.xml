<resources>

    <style name="Theme.Amadeus.Base" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/surface_panel</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/surface_elevated</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/surface_panel</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_card</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/outline_subtle</item>
        <item name="android:windowBackground">@color/surface_background</item>
        <item name="android:colorBackground">@color/surface_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>

    <style name="AppTheme" parent="Theme.Amadeus.Base" />

    <style name="Theme.AppCompat.Light.NoActionBar.Transparent" parent="Theme.Amadeus.Base">
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <style name="Theme.Amadeus.ConfigPrimaria" parent="Theme.Amadeus.Base" />

    <style name="TextAppearance.App.Hint.Personalizado" parent="@style/TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="TextAppearance.App.Error.Personalizado" parent="@style/TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/colorPrimaryDark</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="BotaoOkay" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="barraProgressoPersonalizada" parent="@style/Theme.AppCompat">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="android:color">@color/colorPrimary</item>
    </style>

</resources>
