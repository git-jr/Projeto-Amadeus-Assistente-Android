package com.paradoxo.amadeus.dao.room

import android.content.Context
import android.database.sqlite.SQLiteDatabase
import android.util.Log

/**
 * Gerencia o ciclo de migração do banco de dados para usuários que já possuem o app instalado.
 *
 * Fluxo:
 *   1. SplashScreenActivity chama [precisaMigrar] antes de abrir o banco Room.
 *   2. Se verdadeiro, exibe a tela "Migrando banco de dados..." e chama [executar].
 *   3. [executar] simplesmente abre o banco via AmadeusDatabase.getInstance(); o Room
 *      detecta a versão 4 e executa MIGRATION_4_5 automaticamente dentro de uma transação.
 *   4. O resultado (sucesso/falha) é retornado ao SplashScreen para tratamento de erro.
 */
object MigracaoManager {

    private const val TAG = "MigracaoManager"
    private const val DB_NAME = "Amadeus.db"
    private const val VERSAO_ROOM = 5

    sealed class Resultado {
        object Sucesso : Resultado()
        data class Falha(val erro: Throwable) : Resultado()
    }

    /**
     * Verifica se o banco existente está em uma versão anterior ao Room (v5).
     * Retorna false em instalações novas (arquivo não existe ainda).
     */
    fun precisaMigrar(context: Context): Boolean {
        val dbFile = context.getDatabasePath(DB_NAME)
        if (!dbFile.exists()) return false

        return try {
            val db = SQLiteDatabase.openDatabase(
                dbFile.path,
                null,
                SQLiteDatabase.OPEN_READONLY
            )
            val versaoAtual = db.version
            db.close()
            val migracaoNecessaria = versaoAtual in 1 until VERSAO_ROOM
            Log.i(TAG, "Versão do banco: $versaoAtual — migração necessária: $migracaoNecessaria")
            migracaoNecessaria
        } catch (e: Exception) {
            Log.e(TAG, "Erro ao ler versão do banco", e)
            false
        }
    }

    /**
     * Executa a migração abrindo o banco Room.
     * O Room detecta a versão atual e aplica MIGRATION_4_5 automaticamente.
     * Toda a operação roda dentro de uma transação gerenciada pelo Room.
     *
     * Deve ser chamado em uma coroutine com dispatcher IO.
     */
    fun executar(context: Context): Resultado {
        return try {
            // Abre o banco — Room aplica MIGRATION_4_5 se versão == 4
            AmadeusDatabase.getInstance(context)
            Log.i(TAG, "Migração concluída com sucesso")
            Resultado.Sucesso
        } catch (e: Exception) {
            Log.e(TAG, "Falha durante migração", e)
            Resultado.Falha(e)
        }
    }
}
